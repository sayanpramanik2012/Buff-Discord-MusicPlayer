# ─── Discord Bot ──────────────────────────────────────────────────────────────
# Required: get from https://discord.com/developers/applications
BOT_TOKEN=your_discord_bot_token_here

# Default command prefix (users can override per-server via the dashboard)
PREFIX=#

# ─── Spotify (optional — enables Spotify link support) ────────────────────────
# Get credentials at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ─── Web Dashboard ────────────────────────────────────────────────────────────
FLASK_PORT=5000

# Random secret key for Flask session encryption — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Discord OAuth2 for dashboard login — from your application's OAuth2 tab
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth2_client_secret

# Must match the redirect URI added in your Discord application's OAuth2 settings
OAUTH_REDIRECT_URI=http://localhost:5000/auth/callback

# Comma-separated Discord user IDs that receive admin access on first login
# Example: ADMIN_USER_IDS=123456789012345678,987654321098765432
ADMIN_USER_IDS=your_discord_user_id_here

# ─── YouTube anti-bot (optional) ──────────────────────────────────────────────
# If the bot gets "Sign in to confirm you're not a bot" errors, export a
# cookies.txt (Netscape format) from a logged-in browser and set this path.
# Leave blank to rely on the player-client fallback (tv_embedded / ios) alone.
# YT_COOKIES_FILE=cookies.txt
